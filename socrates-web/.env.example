VIRUSTOTAL_API_KEY=your_key
SHODAN_API_KEY=your_key
ABUSEIPDB_API_KEY=your_key
OTX_API_KEY=your_key
URLSCAN_API_KEY=your_key
ANTHROPIC_API_KEY=your_key
# Optional: triage agent tool loop (default claude-sonnet-4-20250514)
# ANTHROPIC_TRIAGE_MODEL=claude-sonnet-4-20250514
OPENAI_API_KEY=your_key_fallback

# Supabase (optional — enables result caching and history writes)
# Use the service_role key from Supabase → Settings → API (server-side only).
# If you only set the anon key, INSERTs usually fail when RLS is enabled on ioc_queries.
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx

# Frontend (Vite) — alerts dashboard: build picks up the same names many Vercel/Supabase templates use:
#   SUPABASE_URL + NEXT_PUBLIC_SUPABASE_ANON_KEY
# Or explicitly: VITE_SUPABASE_URL + VITE_SUPABASE_ANON_KEY

# Optional: log safe Supabase env diagnostics (host + which keys are set, never values)
# SOCRATES_SUPABASE_DEBUG=1

# Phase 2 IOC extractor: extra comma-separated domains to treat as benign (default list includes microsoft.com, google.com, …)
# SOCrates_DOMAIN_WHITELIST=example.com,cdn.example.net
