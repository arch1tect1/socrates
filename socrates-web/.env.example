# Supabase (optional — enables result caching and history writes)
# Use the service_role key from Supabase → Settings → API (server-side only).
# If you only set the anon key, INSERTs usually fail when RLS is enabled on ioc_queries.
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx
