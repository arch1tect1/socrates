# Optional: absolute path for profiles + decisions (default: ./data)
# DATA_DIR=/var/lib/socrates/data

TELEGRAM_BOT_TOKEN=
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
SHODAN_API_KEY=
URLSCAN_API_KEY=
OTX_API_KEY=

# LLM: if ANTHROPIC_API_KEY is non-empty, the bot uses Claude; otherwise OpenAI (ChatGPT API).
# At least one of the two keys is required.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional model overrides (see Anthropic / OpenAI docs for current model IDs)
# CLAUDE_MODEL=claude-sonnet-4-20250514
# OPENAI_MODEL=gpt-4o-mini

# PostgreSQL database URL (required).
# Railway provides a free PostgreSQL addon — add it in the Railway dashboard
# and it will populate this variable automatically.
DATABASE_URL=postgresql://user:password@localhost:5432/socrates

# Admin Telegram ID — restricts the /admin command to this user only.
# Find your numeric Telegram ID by sending /start to @userinfobot on Telegram.
ADMIN_TELEGRAM_ID=YOUR_TELEGRAM_ID_HERE

# Prometheus metrics HTTP port (default 9090)
# METRICS_PORT=9090

# Each verdict in Telegram ends with a line like: LLM: Claude (model) or LLM: OpenAI ChatGPT API (model)
